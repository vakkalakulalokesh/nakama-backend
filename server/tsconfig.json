{
  "files": [
    "./src/main.ts"
  ],
  "compilerOptions": {
    "target": "es5",
    "typeRoots": [
      "./types"
    ],
    "types": [
      "nakama-runtime"
    ],
    "outFile": "./build/index.js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
